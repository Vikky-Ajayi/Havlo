modules = ["nodejs-20", "python-3.12", "web"]
[agent]
expertMode = true

[nix]
channel = "stable-25_05"

[userenv]

[userenv.shared]
APP_ENV = "development"
ALLOWED_ORIGINS = "https://www.heyhavlo.com,http://localhost:5000,https://localhost:5000"
SESSION_FEE_AMOUNT = "200"
SESSION_FEE_CURRENCY = "USD"
FRONTEND_URL = "https://www.heyhavlo.com"
CALENDLY_LINK = "https://calendly.com/vikkyoluwabukunmi/30min"
SUPABASE_DB_PORT = "6543"
SUPABASE_DB_NAME = "postgres"

[workflows]
runButton = "Project"

[[workflows.workflow]]
name = "Project"
mode = "parallel"
author = "agent"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Start application"

[[workflows.workflow.tasks]]
task = "workflow.run"
args = "Backend API"

[[workflows.workflow]]
name = "Start application"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "cd havlo_frontend && npm run dev"
waitForPort = 5000

[workflows.workflow.metadata]
outputType = "webview"

[[workflows.workflow]]
name = "Backend API"
author = "agent"

[[workflows.workflow.tasks]]
task = "shell.exec"
args = "uvicorn app.main:app --host 0.0.0.0 --port 8000 --log-level info"
waitForPort = 8000

[workflows.workflow.metadata]
outputType = "console"

[[ports]]
localPort = 5000
externalPort = 80

[[ports]]
localPort = 5001
externalPort = 3001

[[ports]]
localPort = 8000
externalPort = 8000

[deployment]
deploymentTarget = "static"
build = ["bash", "-c", "cd havlo_frontend && npm run build"]
publicDir = "havlo_frontend/dist"
