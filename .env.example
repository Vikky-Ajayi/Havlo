# ─── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
SECRET_KEY=your-super-secret-key-change-in-production
ALLOWED_ORIGINS=http://localhost:5173,https://your-vercel-app.vercel.app

# ─── Supabase ───────────────────────────────────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-supabase-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-supabase-service-role-key

# ─── PostgreSQL (Supabase connection string) ────────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres:password@db.your-project.supabase.co:5432/postgres

# ─── Google Sheets ─────────────────────────────────────────────────────────────
# Path to your Google Service Account JSON file, OR paste the JSON contents as a string
GOOGLE_SERVICE_ACCOUNT_JSON=/path/to/service-account.json
# The ID of the Google Spreadsheet (found in the URL)
GOOGLE_SPREADSHEET_ID=your-spreadsheet-id

# ─── Twilio ────────────────────────────────────────────────────────────────────
TWILIO_ACCOUNT_SID=your-twilio-account-sid
TWILIO_AUTH_TOKEN=your-twilio-auth-token
TWILIO_PHONE_NUMBER=+1234567890

# ─── SumUp ─────────────────────────────────────────────────────────────────────
SUMUP_API_KEY=your-sumup-api-key
SUMUP_MERCHANT_CODE=your-sumup-merchant-code

# ─── Calendly ──────────────────────────────────────────────────────────────────
CALENDLY_LINK=https://calendly.com/your-username/consultation

# ─── Session Fee ───────────────────────────────────────────────────────────────
SESSION_FEE_AMOUNT=200
SESSION_FEE_CURRENCY=USD

# ─── Frontend URL (for redirects) ──────────────────────────────────────────────
FRONTEND_URL=https://your-vercel-app.vercel.app
